PORT=3000
NODE_ENV=development

# --- Cơ sở dữ liệu ---
# SKIP_DB=true  → SQLite trong RAM (mất dữ liệu khi tắt server), vẫn đủ để thử API
# SKIP_DB=false → sqlite file hoặc SQL Server tùy DB_DRIVER
SKIP_DB=false

# sqlite (mặc định, file tại server/data/) | mssql
DB_DRIVER=sqlite
SQLITE_PATH=data/finmind.sqlite
# SQLITE_SYNC=false để tắt synchronize (production)

# SQL Server — chỉ khi DB_DRIVER=mssql
SQLSERVER_HOST=localhost
SQLSERVER_PORT=1433
SQLSERVER_USER=sa
SQLSERVER_PASSWORD=YourStrong@Passw0rd
SQLSERVER_DATABASE=finmind
SQLSERVER_SYNCHRONIZE=false

# MongoDB — chỉ khi DB_DRIVER=mssql và bật cờ
MONGODB_ENABLED=false
MONGODB_URI=mongodb://localhost:27017/finmind

OPENAI_API_KEY=

# Google Gemini (AI Advisor) — https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
