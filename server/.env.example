PORT=3000
NODE_ENV=development

# true = không khởi tạo TypeORM + Mongo (chạy API không cần Docker DB)
SKIP_DB=true

# SQL Server — bật khi SKIP_DB=false
SQLSERVER_HOST=localhost
SQLSERVER_PORT=1433
SQLSERVER_USER=sa
SQLSERVER_PASSWORD=YourStrong@Passw0rd
SQLSERVER_DATABASE=finmind
SQLSERVER_SYNCHRONIZE=false

MONGODB_URI=mongodb://localhost:27017/finmind

OPENAI_API_KEY=
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
